# =========================
# 1. 特征工程
# =========================
def add_features(df):
    """
    对原始数据做特征工程
    输入：原始 DataFrame
    输出：加入新特征后的 DataFrame
    """
    df = df.copy()

    # -------- 1）基础二值特征 --------
    # 性别转成二值
    df['gender_bin'] = df['gender'].map({'Male': 1, 'Female': 0}).astype('int8')

    # 下面这些本来是 Yes/No，直接转成 1/0
    for col in ['Partner', 'Dependents', 'PhoneService', 'PaperlessBilling']:
        df[f'{col}_bin'] = df[col].map({'Yes': 1, 'No': 0}).astype('int8')

    # -------- 2）服务相关特征 --------
    # 这些列既可能是 Yes/No，也可能是 No internet service / No phone service
    service_cols = [
        'MultipleLines',
        'OnlineSecurity',
        'OnlineBackup',
        'DeviceProtection',
        'TechSupport',
        'StreamingTV',
        'StreamingMovies'
    ]

    for col in service_cols:
        # 是否开通该服务
        df[f'{col}_Yes'] = (df[col] == 'Yes').astype('int8')

        # 是否属于“没法开通”（比如没网、没电话）
        df[f'{col}_NoService'] = df[col].isin(['No internet service', 'No phone service']).astype('int8')

    # 是否有网络服务
    df['HasInternet'] = (df['InternetService'] != 'No').astype('int8')

    # 网络类型是否为光纤 / DSL
    df['HasFiber'] = (df['InternetService'] == 'Fiber optic').astype('int8')
    df['HasDSL'] = (df['InternetService'] == 'DSL').astype('int8')

    # 是否有电话服务
    df['HasPhone'] = (df['PhoneService'] == 'Yes').astype('int8')

    # 所有互联网增值服务中“开通了几个”
    addon_yes_cols = [
        'OnlineSecurity_Yes',
        'OnlineBackup_Yes',
        'DeviceProtection_Yes',
        'TechSupport_Yes',
        'StreamingTV_Yes',
        'StreamingMovies_Yes'
    ]

    # 偏“保障类”的服务数量
    protection_yes_cols = [
        'OnlineSecurity_Yes',
        'OnlineBackup_Yes',
        'DeviceProtection_Yes',
        'TechSupport_Yes'
    ]

    # 偏“娱乐类”的服务数量
    streaming_yes_cols = [
        'StreamingTV_Yes',
        'StreamingMovies_Yes'
    ]

    # 统计开通服务数量
    df['InternetAddonCount'] = df[addon_yes_cols].sum(axis=1).astype('int8')
    df['ProtectionCount'] = df[protection_yes_cols].sum(axis=1).astype('int8')
    df['StreamingCount'] = df[streaming_yes_cols].sum(axis=1).astype('int8')

    # 总服务数：电话 + 网络 + 多线路 + 互联网增值服务
    df['TotalServiceCount'] = (
        df['HasPhone']
        + df['HasInternet']
        + df['MultipleLines_Yes']
        + df['InternetAddonCount']
    ).astype('int8')

    # -------- 3）合同 / 支付相关特征 --------
    # 合同类型做有序编码：月付 < 一年 < 两年
    contract_map = {
        'Month-to-month': 0,
        'One year': 1,
        'Two year': 2
    }
    df['ContractCode'] = df['Contract'].map(contract_map).astype('int8')

    # 是否月付用户（通常更容易流失）
    df['IsMonthToMonth'] = (df['Contract'] == 'Month-to-month').astype('int8')

    # 是否长期合同用户
    df['IsLongContract'] = df['Contract'].isin(['One year', 'Two year']).astype('int8')

    # 支付方式是否为电子支票
    df['PaymentIsElectronicCheck'] = (df['PaymentMethod'] == 'Electronic check').astype('int8')

    # 是否自动扣款
    df['PaymentIsAuto'] = df['PaymentMethod'].str.contains('automatic', case=False).astype('int8')

    # -------- 4）用户画像类特征 --------
    # 家庭相关标志：有伴侣 + 有家属
    df['FamilySizeFlag'] = (df['Partner_bin'] + df['Dependents_bin']).astype('int8')

    # 是否“独自一人”
    df['IsAlone'] = ((df['Partner_bin'] == 0) & (df['Dependents_bin'] == 0)).astype('int8')

    # 老年人且无伴侣
    df['SeniorNoPartner'] = ((df['SeniorCitizen'] == 1) & (df['Partner_bin'] == 0)).astype('int8')

    # -------- 5）数值交叉特征 --------
    # tenure 为 0 时，后面除法会报错，所以替换成 1
    tenure_safe = df['tenure'].replace(0, 1)

    # 平均每月总收费（理论上应该接近 MonthlyCharges）
    df['AvgChargePerMonth'] = df['TotalCharges'] / tenure_safe

    # 总费用和“月费 * 月数”的差值，可理解为账单误差/额外费用差异
    df['ChargeGap'] = df['TotalCharges'] - df['MonthlyCharges'] * df['tenure']

    # 平均每个服务的月花费
    df['MonthlyChargesPerService'] = df['MonthlyCharges'] / (df['TotalServiceCount'] + 1)

    # 一些交叉项，让模型学习“使用时长 × 消费水平”的关系
    df['Tenure_x_MonthlyCharges'] = df['tenure'] * df['MonthlyCharges']
    df['Tenure_x_TotalCharges'] = df['tenure'] * df['TotalCharges']

    # 新客户 / 老客户
    df['NewCustomer'] = (df['tenure'] <= 6).astype('int8')
    df['LoyalCustomer'] = (df['tenure'] >= 24).astype('int8')

    # -------- 6）分桶特征 --------
    # 将 tenure 分段，帮助模型学习区间规律
    df['TenureGroup'] = pd.cut(
        df['tenure'],
        bins=[-1, 3, 6, 12, 24, 48, 72, np.inf],
        labels=['0-3', '4-6', '7-12', '13-24', '25-48', '49-72', '73+']
    ).astype('object')

    # 将 MonthlyCharges 分成 5 桶
    df['ChargeLevel'] = pd.qcut(
        df['MonthlyCharges'],
        q=5,
        labels=['very_low', 'low', 'mid', 'high', 'very_high'],
        duplicates='drop'
    ).astype('object')

    # -------- 7）类别交叉特征 --------
    # 把两个类别列拼接起来，增强组合关系
    df['Contract_Internet'] = df['Contract'].astype(str) + '_' + df['InternetService'].astype(str)
    df['Contract_Payment'] = df['Contract'].astype(str) + '_' + df['PaymentMethod'].astype(str)
    df['Internet_Payment'] = df['InternetService'].astype(str) + '_' + df['PaymentMethod'].astype(str)

        # -------- 8）少量补充交叉特征（小改动版）--------
    # 新用户 + 月付：通常更容易流失
    df['New_MonthToMonth'] = ((df['NewCustomer'] == 1) & (df['IsMonthToMonth'] == 1)).astype('int8')

    # 光纤 + 电子支票：这个组合在 churn 任务里经常有辨识度
    df['Fiber_ElectronicCheck'] = ((df['HasFiber'] == 1) & (df['PaymentIsElectronicCheck'] == 1)).astype('int8')

    # 长约 + 技术支持：通常是更稳定的用户
    df['LongContract_TechSupport'] = ((df['IsLongContract'] == 1) & (df['TechSupport_Yes'] == 1)).astype('int8')
    return df


# 将 train 和 test 合并一起做特征工程
# 这样可以保证类别编码一致，避免 train/test 列不统一
full = pd.concat(
    [train.drop(columns=[TARGET]), test],
    axis=0,
    ignore_index=True
)

# 执行特征工程
full = add_features(full)

# -------- 8）频率编码 --------
# 频率编码：某个类别在全体数据中出现的频率
# 这是树模型里很常见的一种简单有效的类别增强方式
freq_cols = [
    'InternetService',
    'Contract',
    'PaymentMethod',
    'Contract_Internet',
    'Contract_Payment',
    'Internet_Payment',
    'TenureGroup',
    'ChargeLevel'
]

for col in freq_cols:
    freq_map = full[col].value_counts(normalize=True)
    full[f'{col}_freq'] = full[col].map(freq_map).astype('float32')

# LightGBM 可以直接处理 category 类型
# 所以把 object 类型统一转成 category
cat_cols_full = full.select_dtypes(include='object').columns.tolist()
for col in cat_cols_full:
    full[col] = full[col].astype('category')

# 切分回 train / test
X = full.iloc[:len(train)].copy()
X_test = full.iloc[len(train):].copy()
y = train[TARGET].astype(int)

# 删除 id 列，避免无意义特征干扰模型
if ID_COL in X.columns:
    X = X.drop(columns=[ID_COL])
if ID_COL in X_test.columns:
    X_test = X_test.drop(columns=[ID_COL])

# 记录类别特征列和数值特征列
cat_cols = X.select_dtypes(include='category').columns.tolist()
num_cols = [c for c in X.columns if c not in cat_cols]

print("X shape:", X.shape)
print("X_test shape:", X_test.shape)
print("cat cols:", len(cat_cols))
print("num cols:", len(num_cols))


# =========================
# 2. 定义交叉验证函数
# =========================
def cv_lgb(params, X, y, X_test=None, n_splits=3, seed=42):
    """
    使用 StratifiedKFold 做分层交叉验证
    params: LightGBM 参数
    X, y: 训练数据
    X_test: 测试集（如果传入，就会输出测试集平均预测）
    n_splits: 折数
    seed: 随机种子
    """
    skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=seed)

    # 存储训练集上的 out-of-fold 预测
    oof_pred = np.zeros(len(X))

    # 存储测试集预测（多折平均）
    test_pred = np.zeros(len(X_test)) if X_test is not None else None

    # 每折的 AUC 分数
    fold_scores = []

    # 每折的特征重要性
    fi_list = []

    for fold, (trn_idx, val_idx) in enumerate(skf.split(X, y), 1):
        # 按折切分训练集和验证集
        X_train, X_valid = X.iloc[trn_idx], X.iloc[val_idx]
        y_train, y_valid = y.iloc[trn_idx], y.iloc[val_idx]

        # 定义模型
        model = lgb.LGBMClassifier(
            objective='binary',      # 二分类
            metric='auc',            # 评估指标 AUC
            n_estimators=5000,       # 最大树数，配合 early_stopping 自动提前停止
            random_state=seed + fold,
            n_jobs=-1,
            **params
        )

        # 模型训练
        model.fit(
            X_train, y_train,
            eval_set=[(X_valid, y_valid)],
            eval_metric='auc',
            categorical_feature=cat_cols,
            callbacks=[
                lgb.early_stopping(200),   # 200 轮没有提升就停止
                lgb.log_evaluation(0)      # 不打印每轮日志
            ]
        )

        # 验证集预测概率
        val_pred = model.predict_proba(X_valid)[:, 1]
        oof_pred[val_idx] = val_pred

        # 计算当前折的 AUC
        fold_auc = roc_auc_score(y_valid, val_pred)
        fold_scores.append(fold_auc)
        print(f'Fold {fold} AUC: {fold_auc:.6f}')

        # 如果传入了测试集，就对测试集也预测并做平均
        if X_test is not None:
            test_pred += model.predict_proba(X_test)[:, 1] / n_splits

        # 保存当前折的特征重要性
        fi = pd.DataFrame({
            'feature': X.columns,
            'importance': model.booster_.feature_importance(importance_type='gain'),
            'fold': fold
        })
        fi_list.append(fi)

    # 计算整体 OOF AUC
    overall_auc = roc_auc_score(y, oof_pred)
    print(f'Overall CV AUC: {overall_auc:.6f}')

    fi_df = pd.concat(fi_list, axis=0, ignore_index=True)

    return overall_auc, fold_scores, oof_pred, test_pred, fi_df


