# 3. 随机搜索调参
# =========================
# 用 numpy 的随机数生成器采样参数
rng = np.random.default_rng(42)

def sample_params(rng):
    """
    随机采样一组 LightGBM 参数
    不是最优解，但适合你现在比赛阶段快速试参数
    """
    return {
        'learning_rate': float(rng.choice([0.01, 0.015, 0.02, 0.03, 0.05])),
        'num_leaves': int(rng.choice([31, 63, 95, 127, 159, 191])),
        'max_depth': int(rng.choice([-1, 6, 8, 10, 12])),
        'min_child_samples': int(rng.choice([20, 30, 50, 80, 100, 150])),
        'subsample': float(rng.choice([0.7, 0.75, 0.8, 0.85, 0.9, 1.0])),
        'colsample_bytree': float(rng.choice([0.7, 0.75, 0.8, 0.85, 0.9, 1.0])),
        'reg_alpha': float(rng.choice([0.0, 0.01, 0.05, 0.1, 0.5, 1.0, 3.0])),
        'reg_lambda': float(rng.choice([0.0, 0.01, 0.05, 0.1, 0.5, 1.0, 3.0, 5.0])),
        'min_split_gain': float(rng.choice([0.0, 0.001, 0.005, 0.01, 0.05])),
        'scale_pos_weight': float(rng.choice([1.0, 1.5, 2.0, 2.5, 3.0, 3.44])),
        'verbosity': -1
    }

